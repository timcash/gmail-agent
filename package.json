{
  "name": "gmail-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A simple Gmail agent built on top of googleworkspace/cli",
  "homepage": "https://github.com/googleworkspace/cli",
  "license": "UNLICENSED",
  "scripts": {
    "auth:guide": "node src/gmail-agent.js auth:guide",
    "auth:setup": "node src/gmail-agent.js auth:setup",
    "auth:start": "node src/gmail-agent.js auth:start",
    "auth:login": "node src/gmail-agent.js auth:login",
    "auth:login:daemon": "node src/gmail-agent.js auth:login:daemon",
    "auth:verify": "node src/gmail-agent.js auth:verify",
    "auth:reset": "node src/gmail-agent.js auth:reset",
    "auth:reset:daemon": "node src/gmail-agent.js auth:reset:daemon",
    "auth:doctor": "node src/gmail-agent.js auth:doctor",
    "gmail:profile": "node src/gmail-agent.js gmail:profile",
    "gmail:inbox": "node src/gmail-agent.js gmail:inbox",
    "gmail:search": "node src/gmail-agent.js gmail:search",
    "gmail:read": "node src/gmail-agent.js gmail:read",
    "gmail:send": "node src/gmail-agent.js gmail:send",
    "codex:once": "node src/codex-daemon.js --once",
    "codex:daemon": "node src/codex-daemon.js",
    "codex:daemon:tunnel": "node src/codex-daemon.js --tunnel",
    "codex:demo": "node src/codex-demo.js",
    "codex:e2e": "node src/codex-e2e.js",
    "codex:install-startup": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\install-codex-startup.ps1",
    "codex:remove-startup": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\remove-codex-startup.ps1",
    "gws": "node src/gmail-agent.js gws",
    "test": "node --test"
  },
  "dependencies": {
    "@googleworkspace/cli": "^0.22.5",
    "dotenv": "^17.2.3"
  }
}
