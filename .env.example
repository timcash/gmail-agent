# Option A: easiest local flow
# Put the Desktop OAuth client JSON you downloaded from Google Cloud here:
GMAIL_AGENT_CLIENT_SECRET_FILE=./secrets/client_secret.json

# Option B: instead of a JSON file, paste these values from the same download:
# GOOGLE_WORKSPACE_CLI_CLIENT_ID=
# GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=

# Optional but helpful for quota/billing hints in errors.
# GOOGLE_WORKSPACE_PROJECT_ID=your-google-cloud-project-id
